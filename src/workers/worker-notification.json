{
  "name": "worker-notification",
  "replicas": 1,
  "topics": ["line.messages"],
  "groupId": "worker-notification",
  "downstreamUrl": "http://localhost:5003/incoming",
  "auth": {
    "mode": "oauth2",
    "oauth2TokenUrl": "${NOTIFICATION_OAUTH_TOKEN_URL}",
    "oauth2ClientId": "${NOTIFICATION_OAUTH_CLIENT_ID}",
    "oauth2ClientSecret": "${NOTIFICATION_OAUTH_CLIENT_SECRET}",
    "oauth2Scope": "notify:send"
  }
}
