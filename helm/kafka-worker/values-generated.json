{
  "shared": {
    "kafkaBroker": "host.minikube.internal:9095",
    "image": "kafka-worker:latest",
    "retryCount": 3,
    "retryBaseDelayMs": 1000,
    "fetchTimeoutMs": 5000,
    "pauseDurationMs": 10000
  },
  "workers": [
    {
      "name": "worker-analytics",
      "replicas": 1,
      "topics": [
        "line.messages",
        "line.events"
      ],
      "groupId": "worker-analytics",
      "downstreamUrl": "http://host.minikube.internal:5002/incoming",
      "auth": {
        "mode": "api-key",
        "apiKeyHeader": "X-API-Key",
        "apiKeyValue": "${ANALYTICS_API_KEY}"
      }
    },
    {
      "name": "worker-chat",
      "replicas": 1,
      "topics": [
        "line.messages"
      ],
      "groupId": "worker-chat",
      "downstreamUrl": "http://host.minikube.internal:5001/incoming",
      "auth": {
        "mode": "none"
      }
    },
    {
      "name": "worker-notification",
      "replicas": 1,
      "topics": [
        "line.messages"
      ],
      "groupId": "worker-notification",
      "downstreamUrl": "http://host.minikube.internal:5003/incoming",
      "auth": {
        "mode": "oauth2",
        "oauth2TokenUrl": "${NOTIFICATION_OAUTH_TOKEN_URL}",
        "oauth2ClientId": "${NOTIFICATION_OAUTH_CLIENT_ID}",
        "oauth2ClientSecret": "${NOTIFICATION_OAUTH_CLIENT_SECRET}",
        "oauth2Scope": "notify:send"
      }
    }
  ],
  "secrets": {
    "ANALYTICS_API_KEY": "analytics-secret-key-12345",
    "NOTIFICATION_OAUTH_TOKEN_URL": "http://localhost:4000/oauth2/token",
    "NOTIFICATION_OAUTH_CLIENT_ID": "notification-worker",
    "NOTIFICATION_OAUTH_CLIENT_SECRET": "super-secret-123"
  }
}