# Secrets สำหรับ workers — copy เป็น .env แล้วใส่ค่าจริง
# ใช้: source .env && WORKER_NAME=worker-analytics npm start

# worker-analytics
ANALYTICS_API_KEY=your-api-key-here

# worker-notification (oauth2)
NOTIFICATION_OAUTH_TOKEN_URL=http://localhost:4000/oauth2/token
NOTIFICATION_OAUTH_CLIENT_ID=your-client-id
NOTIFICATION_OAUTH_CLIENT_SECRET=your-client-secret
